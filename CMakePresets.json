{
    "version": 8,
    "configurePresets": [
        {
            "name": "win32-x64-msvc-debug",
            "displayName": "Windows x64 MSVC (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            }
        },
        {
            "name": "win32-x64-mingw-debug",
            "displayName": "Windows x64 MinGW (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "gcc.exe",
                "CMAKE_CXX_COMPILER": "g++.exe"
            }
        },
        {
            "name": "win32-x64-msvc-release",
            "displayName": "Windows x64 MSVC (Release)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            }
        },
        {
            "name": "win32-x64-mingw-release",
            "displayName": "Windows x64 MinGW (Release)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "gcc.exe",
                "CMAKE_CXX_COMPILER": "g++.exe"
            }
        }
    ],

    "buildPresets": [
        {
            "name": "win32-x64-msvc-debug",
            "displayName": "Debug x64 (MSVC)",
            "configurePreset": "win32-x64-msvc-debug",
            "jobs": 4
        },
        {
            "name": "win32-x64-mingw-debug",
            "displayName": "Debug x64 (MinGW)",
            "configurePreset": "win32-x64-mingw-debug",
            "jobs": 4
        },
        {
            "name": "win32-x64-msvc-release",
            "displayName": "Release x64 (MSVC)",
            "configurePreset": "win32-x64-msvc-release",
            "jobs": 4
        },
        {
            "name": "win32-x64-mingw-release",
            "displayName": "Release x64 (MinGW)",
            "configurePreset": "win32-x64-mingw-release",
            "jobs": 4
        }
    ]
}
